# NDI NLP-Konfiguration – Meilenstein M2
# Datei: services/ingest/nlp_config.yaml
#
# Alle Parameter sind zur Laufzeit anpassbar.
# Änderungen wirken beim nächsten NLP-Job-Start.
# Ein Neustart des NLP-Workers ist NICHT erforderlich.
#
# YAML-Hinweis: Regex-Patterns müssen in einfachen Anführungszeichen stehen
# damit \b und andere Escape-Sequenzen korrekt interpretiert werden.

# ─────────────────────────────────────────────────────────────────────────────
# spaCy-Grundpipeline
# ─────────────────────────────────────────────────────────────────────────────
spacy:
  # Deutsches Sprachmodell
  # Alternativen: de_core_news_sm (schnell), de_core_news_md, de_core_news_lg (genau)
  model: "de_core_news_lg"

  # Aktive Pipeline-Komponenten
  components:
    - tagger
    - parser
    - lemmatizer

  # Maximale Textlänge pro Chunk (Zeichen)
  max_text_length: 100000

  # Batch-Größe für spaCy nlp.pipe()
  batch_size: 32

# ─────────────────────────────────────────────────────────────────────────────
# SVO-Extraktion
# ─────────────────────────────────────────────────────────────────────────────
svo:
  min_confidence: 0.5
  max_subject_length: 120
  max_object_length: 200

  # ── Stoppwort-Filter ────────────────────────────────────────────────────
  # Schicht 1: Diese Wörter als Subjekt komplett verwerfen
  stop_subjects:
    # Artikel und Pronomen
    - "er"
    - "sie"
    - "es"
    - "man"
    - "dies"
    - "diese"
    - "dieser"
    - "dieses"
    - "der"
    - "die"
    - "das"
    - "dem"
    - "den"
    - "wer"
    # Abkürzungen und Fragmente
    - "s. 3"
    - "s. 2"
    - "s. 1"
    - "s. 4"
    - "abs. 1"
    - "abs. 2"
    - "abs. 3"
    - "nr. 1"
    - "nr. 2"
    # Allgemeine Wörter die kein sinnvolles Subjekt sind
    - "folgendes"
    - "nachfolgendes"
    - "vorstehende"

  # Schicht 1: Diese Wörter als Objekt komplett verwerfen
  stop_objects:
    # Artikel und Pronomen
    - "der"
    - "die"
    - "das"
    - "dem"
    - "den"
    - "dies"
    - "diese"
    - "es"
    # Adjektive die fälschlich als Objekt erkannt werden
    - "erforderlich"
    - "zulässig"
    - "gebührenpflichtig"
    - "anmeldepflichtig"
    - "gefährlich"
    - "bekannt"
    - "unberührt"
    - "entsprechend"
    - "zuständig"
    - "zuständige"
    - "so erlaubt"
    - "einschlägig"
    - "für Halten"
    - "für Führen"
    - "für Haltung"
    # Dokumentkopf-Artefakte
    - "Aktuell Tiergesundheit"
    - "Aktuell"
    - "Microsoft Word"
    # Sehr kurze Präpositionsfragmente
    - "für das"
    - "für die"
    - "für den"
    # Adverbiale Phrasen-Fragmente
    - "im übrigen"
    - "im wesentlichen"
    - "in regel"
    - "in der regel"
    - "im einzelfall"
    - "auf antrag"
    - "auf anfrage"
    - "nach maßgabe"
    - "durch gesetz"
    - "durch verordnung"
    - "nach bedarf"
    - "im rahmen"
    - "nach lage"
    - "nach art"
    - "nach absatz"
    - "nach satz"

  # Minimale Zeichenlänge für Subjekt/Objekt (filtert Einzelzeichen)
  min_subject_length: 3
  min_object_length: 3

  # Schicht 2: Pronomen-Subjekte NICHT verwerfen, aber Konfidenz reduzieren.
  # Der Normtyp und das Objekt bleiben nützlich für die RAG-Engine.
  pronouns:
    - "er"
    - "sie"
    - "es"
    - "man"
    - "wer"
    - "dies"
    - "dieser"
    - "diese"
    - "dieses"
  pronoun_confidence_penalty: 0.3   # Abzug auf Gesamt-Konfidenz

  subject_deps:
    - "sb"
    - "sp"
    - "nsubj"

  object_deps:
    - "oa"     # Akkusativobjekt (deutsch)
    - "og"     # Genitivobjekt (deutsch)
    - "op"     # Präpositionalobjekt (deutsch)
    - "oc"     # Objektsatz/Infinitiv (deutsch)
    - "pd"     # Prädikativum (deutsch) – für DEF: "ist [natürliche Person]"
    - "obj"    # Objekt (universal)
    - "obl"    # obliques Nominal (universal)
    - "da"     # Dativobjekt (deutsch) – "dient der Umsetzung"
    - "mo"     # Modifikator (deutsch) – ergänzende Phrasen
    - "nk"     # Nominalphrase-Kern (deutsch)
    - "attr"   # Attribut

  # Prädikate die als Substantive fälschlich als Verben erkannt werden
  # Werden in Schicht 3 des SVO-Filters verworfen
  stop_predicates:
    # Interpunktion und Abkürzungen als Prädikat
    - "§"
    - "S."
    - "Nr."
    - "Abs."
    - "Art."
    # Substantive als Prädikat (False Positives)
    - "Hundegesetz"
    - "Hundeführerschein"
    - "Preisfeststellung"
    - "Preisfeststellungen"
    - "Landesamt"
    - "TIERSCHUTZ"
    - "Ausnahme"
    - "Voraussetzung"
    - "Grundlage"
    - "Maßgabe"
    - "Aktuell"
    - "Presse"
    - "Veranstaltungen"
    # Neue Artefakte aus UNKNOWN-Analyse
    - "Stelle"
    - "Satz"
    - "Hunderegister"
    - "VOR"
    - "BHV-Hundeführerscheinprüfung"
    - "DHVE-Hundeführerscheinprüfung"
    - "Bedarfsgegenstände"
    - "Bedarfsgegenstand"

  subject_type_patterns:
    suffixes:
      "behörde": "BEHÖRDE"
      "ministerium": "BEHÖRDE"
      "amt": "BEHÖRDE"
      "stelle": "BEHÖRDE"
      "register": "BEHÖRDE"
      "halter": "ROLLE"
      "halterin": "ROLLE"
      "inhaber": "ROLLE"
      "inhaberin": "ROLLE"
      "person": "ROLLE"
      "antragsteller": "ROLLE"
    exact:
      "gemeinde": "BEHÖRDE"
      "fachbehörde": "BEHÖRDE"
      "fachministerium": "BEHÖRDE"

  object_type_patterns:
    suffixes:
      "daten": "DATENOBJEKT"
      "register": "DATENOBJEKT"
      "nummer": "DATENOBJEKT"
      "nachweis": "DATENOBJEKT"
      "bescheinigung": "DATENOBJEKT"
      "erlaubnis": "DATENOBJEKT"
      "pflicht": "ANFORDERUNG"
      "pflichten": "ANFORDERUNG"
      "verbot": "ANFORDERUNG"
    exact:
      "sachkunde": "ANFORDERUNG"
      "transponder": "DATENOBJEKT"

# ─────────────────────────────────────────────────────────────────────────────
# Normtyp-Klassifikation
# WICHTIG: Regex-Patterns in einfachen Anführungszeichen!
# ─────────────────────────────────────────────────────────────────────────────
normtypen:

  MUST:
    patterns:
      # ── Modalverben (Einzel-Wort – trifft auch auf Prädikat-Text) ────────
      - '\bmuss\b'
      - '\bmüssen\b'
      - '\bsoll\b'
      - '\bsollen\b'
      # ── hat/haben + zu ───────────────────────────────────────────────────
      - '\bhat\s+zu\b'
      - '\bhaben\s+zu\b'
      - '\bhat\s+sicherzustellen\b'
      # ── ist/sind + zu (kurze Form – trifft auf Prädikat) ─────────────────
      - '\bist\s+zu\b'
      - '\bsind\s+zu\b'
      # ── Verpflichtungs-Adjektive ─────────────────────────────────────────
      - '\bist\s+verpflichtet\b'
      - '\bsind\s+verpflichtet\b'
      - '\bpflichtig\b'            # anmeldepflichtig, gebührenpflichtig
      - '\berforderlich\b'
      # ── Passiv-Infinitive (einzelne Verben) ──────────────────────────────
      - '\bdurchzuführen\b'
      - '\bnachzuweisen\b'
      - '\banzumelden\b'
      - '\bmitzuführen\b'
      - '\beinzuhalten\b'
      - '\bsicherzustellen\b'
      - '\banzugeben\b'
      - '\banzuzeigen\b'
      - '\bvorzulegen\b'
      - '\bbeizubringen\b'
      - '\bzu\s+machen\b'
      # ── bedarf / unterliegt (Einzel-Wort) ────────────────────────────────
      - '\bbedarf\b'
      - '\bbedürfen\b'
      - '\bunterl(ie|a)gt\b'
      - '\bunterliegen\b'
      # ── Verbpräfix-Pflichten ──────────────────────────────────────────────
      - '\bmitführen\b'
      - '\banmelden\b'
      - '\bnachweisen\b'
    confidence_boost: 0.0

  MAY:
    patterns:
      # ── Modalverben ──────────────────────────────────────────────────────
      - '\bkann\b'
      - '\bkönnen\b'
      - '\bdarf\b'
      - '\bdürfen\b'
      # ── Berechtigung ─────────────────────────────────────────────────────
      - '\bberechtigt\b'
      - '\bbefugt\b'
      - '\bgestattet\b'
      - '\bzulässig\b'
      # ── Passiv-Erlaubnis (einzelne Verben) ───────────────────────────────
      - '\berteilt\b'
      - '\bzugelassen\b'
      - '\banerkannt\b'
      - '\babgewickelt\b'
      - '\bbezogen\b'              # können bezogen werden
      # ── gilt als ─────────────────────────────────────────────────────────
      - '\bgilt\s+als\b'
    confidence_boost: 0.0

  MUST_NOT:
    patterns:
      - '\bdarf\s+nicht\b'
      - '\bdürfen\s+nicht\b'
      - '\bist\s+untersagt\b'
      - '\bsind\s+untersagt\b'
      - '\bist\s+verboten\b'
      - '\bist\s+nicht\s+gestattet\b'
    confidence_boost: 0.05

  DEF:
    patterns:
      - '\bim\s+Sinne\s+dieses\b'
      - '\bim\s+Sinne\s+dieser\b'
      - '\bim\s+Sinne\s+des\b'
      - '\bgilt\s+als\b'
    confidence_boost: 0.1

  EXCEPT:
    patterns:
      - '\bes\s+sei\s+denn\b'
      - '\bsofern\s+nicht\b'
      - '\bausgenommen\b'
      - '\bausnahmsweise\b'
      - '\bunbeschadet\b'
      # ── Konjunktiv II (Bedingung/Ausnahme) ──────────────────────────────
      - '\bwürde\b'
      - '\bwürden\b'
      - '\bwäre\b'
      - '\bwären\b'
    confidence_boost: 0.0

  DEADLINE:
    patterns:
      - '\bbinnen\b'
      - '\bspätestens\b'
      - '\bunverzüglich\b'
      - '\binnerhalb\s+von\b'
      - '\bfristgerecht\b'
      - '\bvor\s+Ablauf\b'
    confidence_boost: 0.05

  COMPETENCE:
    patterns:
      - '\bzuständig\s+ist\b'
      - '\bobliegt\b'
      - '\bist\s+zuständig\b'
      - '\bwird\s+wahrgenommen\s+von\b'
      # ── Neu: aus UNKNOWN-Analyse ─────────────────────────────────────────
      - '\büberwacht\b'            # überwacht die Einhaltung
      - '\bführt\b'               # führt das Register
      - '\bwird\s+geführt\b'     # wird geführt durch
      - '\bnimmt\s+ab\b'         # nimmt die Prüfung ab
      - '\babnimmt\b'
      - '\berteilt\b'             # erteilt die Erlaubnis (aktiv)
      - '\bwacht\s+.*\s+über\b' # wacht über die Einhaltung
    confidence_boost: 0.0

  # ── Neuer Normtyp: SCOPE (Geltungsbereich) ─────────────────────────────────
  SCOPE:
    patterns:
      - '\bgilt\s+für\b'
      - '\bfindet\s+.*\s+Anwendung\b'
      - '\bfindet\s+Anwendung\b'
      - '\bAnwendung\s+findet\b'
      - '\bgilt\s+entsprechend\b'
      - '\bgilt\s+auch\b'
      - '\bdient\s+der\s+Umsetzung\b'
      - '\bdient\s+der\b'
      - '\bdient\s+dem\b'
      - '\bdient\b'              # dient generell
      - '\bfindet\s+statt\b'
      - '\bfindet\s+Verwendung\b'
      - '\bfindet\b'             # findet generell (findet Anwendung etc.)
      - '\bgilt\b'               # gilt generell
      - '\bgelten\b'
    confidence_boost: 0.0

  # ── Neuer Normtyp: CHANGE (Rechtsänderung) ──────────────────────────────────
  CHANGE:
    patterns:
      - '\bgeändert\b'
      - '\bgeändert\s+worden\b'
      - '\bwird\s+geändert\b'
      - '\bersetzen\b'
      - '\bersetzt\b'
      - '\bgefasst\b'
      - '\bneu\s+gefasst\b'
      - '\baufgehoben\b'
      - '\baufheben\b'
    confidence_boost: 0.0

  # ── Neuer Normtyp: STATUS (Zustandsbeschreibung) ────────────────────────────
  # "ist" + Adjektiv/Substantiv wenn kein anderes Pattern passt
  STATUS:
    patterns:
      # ist/sind + Zustandsadjektiv
      - '\bist\s+zugelassen\b'
      - '\bist\s+anerkannt\b'
      - '\bist\s+registriert\b'
      - '\bist\s+eingetragen\b'
      - '\bist\s+bekannt\b'
      - '\bsind\s+bekannt\b'
      - '\bist\s+in\s+Kraft\b'
      # hat/haben + Objekt (Besitz/Zustand)
      - '\bhat\s+die\s+Zulassung\b'
      - '\bhat\s+eine\s+Erlaubnis\b'
      - '\bhat\s+den\s+Nachweis\b'
      - '\bhat\s+.*\s+Kenntnisse\b'
      - '\bhat\s+.*\s+Erfahrung\b'
      # besitzt
      - '\bbesitzt\b'
      # stellt
      - '\bstellt\s+sicher\b'
      - '\bstellt\s+fest\b'
      - '\bstellt\b'             # stellt generell
      # macht
      - '\bmacht\s+.*\s+geltend\b'
      - '\bmacht\b'              # macht generell
      # wird + Passiv-Zustand
      - '\bwird\s+bekannt\s+gemacht\b'
      - '\bwird\s+.*\s+mitgeteilt\b'
      - '\bwird\b'               # wird generell (Passiv-Hilfszeitwort)
      - '\bwerden\b'
      # hat generell (Zustandsbeschreibung)
      - '\bhat\b'
      # ist/sind generell als Fallback für Zustandsbeschreibungen
      - '\bist\b'
      - '\bsind\b'
    confidence_boost: 0.0

# ─────────────────────────────────────────────────────────────────────────────
# NER – Named Entity Recognition
# WICHTIG: Regex-Patterns in einfachen Anführungszeichen!
# ─────────────────────────────────────────────────────────────────────────────
ner:
  rules_enabled: true

  # Flair Legal NER – Stufe 2
  # Trainiert auf dem German LER-Datensatz (67.000 Sätze, Bundesgerichtsentscheidungen)
  # 19 feingranulare juristische Entitätsklassen
  flair_enabled: true
  flair_model: "flair/ner-german-legal"    # HuggingFace-ID oder lokaler Pfad

  # Kombinationsstrategie wenn beide Stufen aktiv:
  # "merge"    → Flair-Ergebnisse + Regelbasiert kombiniert (empfohlen)
  # "flair_only" → nur Flair-Ergebnisse
  # "rules_only" → nur regelbasierte Ergebnisse
  combination_strategy: "merge"

  # Mindest-Konfidenz
  min_confidence: 0.6
  flair_min_confidence: 0.75   # Angepasst: 0.75 liefert mehr Flair-Ergebnisse bei akzeptabler Qualität

  # Ansatz 5: §-Normreferenzen aus GESETZ-Entitäten filtern
  # true  = §-Nummern ohne Gesetzesname werden verworfen (§ 8, § 10 Abs. 4)
  # false = alle §-Entitäten behalten (auch reine Normreferenzen)
  filter_norm_references: true

  # ── Ansatz 1: Blacklist ──────────────────────────────────────────────────
  # Entitäten die NIE gespeichert werden – unabhängig von Quelle und Konfidenz.
  # Groß-/Kleinschreibung wird ignoriert.
  blacklist:
    # Tech-Konzerne (häufige False Positives in Gerichtsentscheidungen)
    - "Google"
    - "Apple"
    - "Microsoft"
    - "Amazon"
    - "Facebook"
    - "Meta"
    - "Twitter"
    - "Instagram"
    - "YouTube"
    - "LinkedIn"
    # Rechtsformen (werden oft fälschlich als Behörde klassifiziert)
    - "GmbH"
    - "AG"
    - "GbR"
    - "OHG"
    - "KG"
    - "e.V."
    - "e. V."
    # Sonstige bekannte False Positives (hier ergänzen)

  # ── Ansatz 2: Label-Korrekturen ──────────────────────────────────────────
  # Entität wird NICHT verworfen, aber das Label wird korrigiert.
  # Format: "Text": "NEUES_LABEL"
  # Groß-/Kleinschreibung wird ignoriert.
  label_corrections:
    # Privatunternehmen die als Behörde erkannt werden
    "Telekom":        "SONSTIGE"
    "Deutsche Post":  "SONSTIGE"
    "Bundespost":     "BEHÖRDE"
    "TÜV":            "SONSTIGE"
    "DEKRA":          "SONSTIGE"
    # NER False Positives aus Qualitätsbericht
    "Feststellung":   "SONSTIGE"   # wird fälschlich als GESETZ erkannt
    "Feststellungen": "SONSTIGE"
    "Hundehaltung":   "DATENOBJEKT" # eher Datenobjekt als SONSTIGE
    "Hundehaltungen": "DATENOBJEKT"
    "Antragsteller":  "ROLLE"       # ist eine Rolle, nicht SONSTIGE
    "Antragstellerin": "ROLLE"

  # ── Ansatz 4: Kontext-Validierung ────────────────────────────────────────
  # Ein Label wird nur akzeptiert wenn mindestens eines der Signalwörter
  # im Kontext (±context_window Zeichen) vorkommt.
  # Leere Liste = keine Kontext-Prüfung für dieses Label.
  context_validation:
    enabled: true
    context_window: 80           # Zeichen vor/nach der Entität

    BEHÖRDE:
      # Mindestens eines dieser Wörter muss im Kontext stehen
      required_context:
        - "behörde"
        - "amt"
        - "ministerium"
        - "gericht"
        - "zuständig"
        - "überwacht"
        - "anordnung"
        - "bescheid"
        - "verwaltung"
        - "kommune"
        - "landkreis"
        - "gemeinde"
      # Wenn keins gefunden → auf dieses Label herabstufen (statt verwerfen)
      fallback_label: "SONSTIGE"

    GESETZ:
      required_context:
        - "§"
        - "abs"
        - "satz"
        - "gesetz"
        - "verordnung"
        - "richtlinie"
        - "art."
        - "artikel"
      fallback_label: "SONSTIGE"

    ROLLE:
      required_context: []       # keine Kontext-Prüfung für Rollen

  patterns:
    BEHÖRDE:
      suffixes:
        - "behörde"
        - "ministerium"
        - "amt"
        - "register"
        - "stelle"
        - "landesbehörde"
        - "fachbehörde"
      exact:
        - "gemeinde"
        - "gemeinden"
        - "landkreis"
        - "fachministerium"

    ROLLE:
      suffixes:
        - "halter"
        - "halterin"
        - "inhaber"
        - "inhaberin"
        - "antragsteller"
        - "antragstellerin"
        - "beauftragter"
        - "beauftragte"
      exact:
        - "person"
        - "natürliche person"
        - "juristische person"

    DATENOBJEKT:
      suffixes:
        - "daten"
        - "nummer"
        - "kennnummer"
        - "nachweis"
        - "bescheinigung"
        - "erlaubnis"
        - "ausweis"
        - "zeugnis"
      exact:
        - "transponder"
        - "mikrochip"
        - "sachkundenachweis"

    FRIST:
      regex:
        - '\d+\s+(?:Tag|Tage|Tagen|Woche|Wochen|Monat|Monate|Monaten|Jahr|Jahre|Jahren)'
        - 'binnen\s+\S+'
        - 'innerhalb\s+von\s+\S+'
        - 'unverzüglich'

    GESETZ:
      regex:
        - '§\s*\d+\w*(?:\s+Abs\.\s*\d+)?(?:\s+Satz\s*\d+)?'
        - 'Art\.\s*\d+'
        - '\b[A-Z][a-zA-Z]+G\b'

# ─────────────────────────────────────────────────────────────────────────────
# Fragen-Filter
# ─────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Fragen-Filter
# Zwei unabhängige Schalter:
#   question_filter.ingest → wirkt beim Einlesen der Dokumente (Chunking)
#   question_filter.nlp    → wirkt bei der NLP-Verarbeitung (SVO/NER)
#
# Beide können unabhängig voneinander ein- oder ausgeschaltet werden.
# Änderungen wirken beim nächsten Lauf ohne Neustart.
# ─────────────────────────────────────────────────────────────────────────────
question_filter:

  # ── Ingest-Filter ─────────────────────────────────────────────────────────
  # Wirkt im Chunking-Schritt des Ingest-Service.
  # Erkannte Fragen werden in filtered_questions geloggt.
  ingest:
    # Ingest-Filter aktiv?
    # true  = Fragen werden beim Ingest erkannt, geloggt und gefiltert
    # false = Fragen werden beim Ingest ignoriert (normal verarbeitet)
    enabled: true

    # Dokumentklassen in denen Fragen erkannt werden sollen
    apply_to_classes:
      - "B"
      - "C"

    # Was passiert mit erkannten Fragen beim Ingest?
    # "exclude"         = Frage wird NICHT als Chunk gespeichert, aber geloggt
    # "include"         = Frage wird normal verarbeitet UND geloggt
    # "include_as_type" = Frage wird als chunk_type="frage" gespeichert
    action: "exclude"

  # ── NLP-Filter ────────────────────────────────────────────────────────────
  # Wirkt im NLP-Worker (nlp_worker.py) bei der SVO/NER-Verarbeitung.
  # Chunks mit Fragen werden bei der NLP-Analyse übersprungen oder markiert.
  nlp:
    # NLP-Filter aktiv?
    # true  = Chunks mit Fragen werden beim NLP übersprungen
    # false = Chunks mit Fragen werden normal durch NLP verarbeitet
    enabled: true

    # Dokumentklassen in denen Fragen beim NLP erkannt werden sollen
    apply_to_classes:
      - "B"
      - "C"

    # Was passiert mit Frage-Chunks beim NLP?
    # "skip"   = Chunk wird nicht durch SVO/NER verarbeitet
    # "process" = Chunk wird normal verarbeitet (nur Logging)
    action: "skip"

  # ── Gemeinsame Erkennungsparameter ────────────────────────────────────────
  # Diese Parameter gelten für beide Filter (ingest + nlp).
  detection:
    # Mindestlänge einer Frage in Zeichen
    min_length: 10

    # Maximallänge – längere Texte sind eher Fließtext mit ? am Ende
    max_length: 300

    # Fragezeichen am Ende ist Pflicht?
    require_question_mark: true

    # Einleitende Fragewörter (erhöhen Konfidenz der Erkennung)
    question_words:
      - "wer"
      - "was"
      - "wie"
      - "wo"
      - "wann"
      - "warum"
      - "weshalb"
      - "wozu"
      - "welche"
      - "welcher"
      - "welches"
      - "kann"
      - "darf"
      - "muss"
      - "ist"
      - "sind"
      - "haben"
      - "gibt"

    # Rhetorik-Muster
    rhetorical_patterns:
      - "aber warum"
      - "doch wie"
      - "oder etwa"
      - "wirklich"

    # Kontext-Fenster (Zeichen) für context_before / context_after
    context_window: 150

# ─────────────────────────────────────────────────────────────────────────────
# Worker-Konfiguration
# ─────────────────────────────────────────────────────────────────────────────
# ── LLM-Normtyp-Klassifikation ───────────────────────────────────────────────
# Klassifiziert UNKNOWN-SVOs nach der spaCy-Extraktion via LLM-Gateway.
# Voraussetzung: LLM-Gateway konfiguriert (llm_gateway_config.yaml)
#                Prompt ps_normtyp vorhanden (prompt_suite/ps_normtyp/)

llm_normtyp:
  enabled:         true   # false = nur spaCy, kein LLM-Aufruf
  batch_size:      20     # SVOs pro LLM-Batch
  min_confidence:  0.75   # LLM-Konfidenz unter diesem Wert → UNKNOWN bleibt

  # Test-Budget: Maximale Anzahl Batches pro NLP-Lauf
  # 0 = unbegrenzt (Produktion)
  # z.B. 3 = nur 3 Batches à 20 SVOs = max. 60 LLM-klassifizierte SVOs
  test_max_batches: 0

  # Pause zwischen Batch-Calls in Sekunden
  # Da jetzt 20 SVOs = 1 API-Call: Pause zwischen den Batches
  # Free-Tier Gemini: 1-2s reicht (viel weniger Calls)
  # On-Premise Ollama: 0
  delay_sek: 1.0

  # Prompts und Antworten in Logfile schreiben
  # Logfiles unter: services/ingest/logs/llm_normtyp_DATUM.log
  log_prompts: true

worker:
  process_classes:
    - "A"
    - "B"
    - "C"

  chunk_batch_size: 50
  overwrite_existing: true
  min_token_count: 10
  num_workers: 1
  show_progress: true
